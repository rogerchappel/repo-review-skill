{
  "name": "@rogerchappel/repo-review-skill",
  "version": "1.0.0",
  "description": "Review any code repo like a practical maintainer; output prioritized, testable improvement tasks for agents.",
  "main": "src/index.js",
  "bin": {
    "repo-review-skill": "bin/repo-review-skill.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "check": "node --check src/*.js",
    "smoke": "bin/repo-review-skill.js ./fixtures/demo-repo --out ./_review_out --no-fs-write",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "repo-review",
    "agent-skill",
    "maintenance",
    "quality-audit",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/repo-review-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/repo-review-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/repo-review-skill#readme",
  "files": [
    "src",
    "bin",
    "fixtures",
    "docs",
    "README.md"
  ]
}
